# Frontend public env vars (Vite)
# Copia este archivo a .env.local (desarrollo) o .env.staging (pruebas)

# Backend URL
VITE_BACKEND_URL=https://tu-backend.vercel.app

# Firebase Web App config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloudinary (admin upload de imagenes)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_FOLDER_PREFIX=enarmonia
